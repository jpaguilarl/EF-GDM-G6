# Copiar a .env y completar. .env real NUNCA se commitea (ver .gitignore).

# --- Storage: local (default) o S3 -----------------------------------------
# local: data/ del repo, exactamente como hoy. s3: todas las capas
# (bronze/silver/gold/profiling + los 3 audit.parquet) leen/escriben en
# s3://S3_BUCKET/S3_PREFIX. Requiere el extra "s3" instalado:
#   uv sync --extra s3
STORAGE_BACKEND=local

# Credenciales AWS (solo necesarias si STORAGE_BACKEND=s3). Se leen del
# entorno via el proveedor de credenciales estandar de AWS — nunca se
# hardcodean en config.yaml ni en el codigo.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=
S3_PREFIX=tlc-pipeline

# --- Airflow (docker-compose.yml) -------------------------------------------
# UID del usuario airflow dentro del contenedor; en Linux usar `id -u` del
# host para que los archivos escritos en volumenes monteados sean editables
# fuera del contenedor. En Windows/Docker Desktop, dejar el default.
AIRFLOW_UID=50000

AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres/airflow
AIRFLOW__CORE__FERNET_KEY=

# Deteccion de zombies: un commit lento en S3 puede pasar del default de 300s y
# hacer que el scheduler mate la task y lance el retry -> dos procesos Spark
# escribiendo al mismo prefijo (carrera de commit). 1800s (30 min) da margen al
# commit sin dejar de detectar procesos muertos de verdad.
AIRFLOW__SCHEDULER__SCHEDULER_ZOMBIE_TASK_THRESHOLD=1800
AIRFLOW__SCHEDULER__JOB_HEARTBEAT_SEC=5

# --- Recursos de Spark ------------------------------------------------------
# Override de heap y cores de la JVM de Spark (app/utils/spark.py). Bare-metal
# (`uv run`) sin estas vars usa el default calibrado 10g/local[10] (maquina de
# 32GB/16 cores). En Docker, docker-compose.yml ya baja el default a 8g/local[8]
# porque el VM de WSL2 comparte RAM con Airflow + Postgres; ajusta aqui si tu VM
# tiene mas/menos. NO bajar cores sin bajar el heap en la misma proporcion.
SPARK_DRIVER_MEMORY=8g
SPARK_MASTER_CORES=8

_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=admin
